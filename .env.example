# EPI Recognition System - Environment Variables
# Cloud Deployment Configuration

# ==================== SUPABASE CONFIGURATION (CLOUD) ====================
# Get these from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ==================== DATABASE CONFIGURATION (LOCAL - DEPRECATED) ====================
# Use Supabase for cloud deployment instead
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/epi_monitoring

# ==================== YOLO MODEL CONFIGURATION ====================
YOLO_MODEL_PATH=models/yolov8n.pt
DETECTION_CONFIDENCE_THRESHOLD=0.5
IOU_THRESHOLD=0.45

# ==================== CLOUD WORKER CONFIGURATION ====================
# Unique ID for this worker instance (useful when running multiple workers)
WORKER_ID=worker-1

# Camera ID range for worker partitioning (for multi-worker setups)
CAMERA_RANGE_START=0
CAMERA_RANGE_END=999

# Frame processing settings
FRAME_RATE=5  # FPS per camera
FRAMES_PER_BATCH=10  # Number of frames to process per cycle

# Worker heartbeat
WORKER_HEARTBEAT_INTERVAL=30  # seconds
RTSP_CONNECTION_TIMEOUT=10  # seconds

# ==================== CAMERA CONFIGURATION ====================
# Legacy: Comma-separated list (use Supabase cameras table instead)
CAMERA_RTSP_URLS=rtsp://camera1,rtsp://camera2,rtsp://camera3
MAX_CAMERAS=4

# ==================== SAMPLE CAMERA CREDENTIALS (REFERENCE) ====================
# These are examples - add cameras via the Dashboard UI
#
# Hikvision:
# rtsp://username:password@PUBLIC_IP:554/Streaming/Channels/101
#
# Dahua:
# rtsp://username:password@PUBLIC_IP:554/cam/realmonitor?channel=1&subtype=0
#
# Intelbras:
# rtsp://username:password@PUBLIC_IP:554/video1
#
# Generic:
# rtsp://username:password@PUBLIC_IP:554/stream

# Processing Configuration
FRAME_EXTRACTION_INTERVAL=1
MAX_PROCESSING_THREADS=4
BATCH_SIZE=8

# Storage Configuration
STORAGE_DIR=storage
IMAGES_DIR=storage/images
ANNOTATED_IMAGES_DIR=storage/annotated
REPORTS_DIR=storage/reports

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=storage/epi_system.log

# Streamlit Configuration
STREAMLIT_HOST=localhost
STREAMLIT_PORT=8501
STREAMLIT_TITLE=Sistema de Monitoramento de EPI
STREAMLIT_LAYOUT=wide

# Application Configuration
APP_NAME=EPI Recognition System
APP_VERSION=1.0.0
DEBUG=False
TIMEZONE=America/Sao_Paulo

# Report Configuration
DEFAULT_REPORT_FORMAT=pdf

# Alert Configuration
ALERT_EMAIL_ENABLED=False
ALERT_EMAIL_SMTP_SERVER=smtp.gmail.com
ALERT_EMAIL_SMTP_PORT=587
ALERT_EMAIL_USERNAME=
ALERT_EMAIL_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# Notification Configuration
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=

# Performance Configuration
MAX_DETECTION_CACHE_SIZE=1000
MAX_FRAME_QUEUE_SIZE=10
DETECTION_TIMEOUT=30

# Compliance Thresholds
COMPLIANCE_THRESHOLD=0.8
CRITICAL_ALERT_THRESHOLD=0.5
