# === REQUIRED ===
DATABASE_URL=postgresql://user:password@host:5432/dbname
JWT_SECRET_KEY=your-super-secret-key-min-32-chars-long

# === SERVER ===
PORT=5001
FLASK_ENV=development
APP_VERSION=2.0.0

# === CORS (comma-separated whitelist — NEVER use *) ===
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# === STORAGE (Cloudflare R2) ===
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=epi-monitor
R2_ENDPOINT_URL=https://your_account_id.r2.cloudflarestorage.com

# === REDIS (for Celery + SocketIO) ===
REDIS_URL=redis://localhost:6379/0

# === FFmpeg ===
FFMPEG_PRESET=ultrafast
FFMPEG_VIDEO_BITRATE=512k
FFMPEG_RESOLUTION=640x360
HLS_SEGMENT_DURATION=1
HLS_PLAYLIST_SIZE=3

# === YOLO ===
YOLO_MODEL_PATH=models/yolov8n.pt
DETECTION_CONFIDENCE_THRESHOLD=0.5
YOLO_FPS=5

# === JWT ===
JWT_TTL_SECONDS=86400
